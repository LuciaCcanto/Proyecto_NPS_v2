# Application
APP_NAME="360° NPS Platform"
APP_SECRET_KEY="change-this-to-a-random-64-char-secret"
APP_DEBUG=False
APP_HOST=0.0.0.0
APP_PORT=8000

# Database (SQLite for dev, PostgreSQL for prod)
DATABASE_URL="sqlite+aiosqlite:///./nps_platform.db"
# DATABASE_URL="postgresql+asyncpg://user:password@localhost:5432/nps_platform"

# JWT Auth
JWT_SECRET_KEY="change-this-jwt-secret-key"
JWT_ALGORITHM="HS256"
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=480

# OpenAI
OPENAI_API_KEY="sk-..."
OPENAI_MODEL="gpt-4o-mini"
OPENAI_MAX_TOKENS=500

# External Review Links
GOOGLE_REVIEW_URL="https://g.page/r/your-business/review"
TRUSTPILOT_URL="https://www.trustpilot.com/review/yourbusiness.com"

# Webhooks
WHATSAPP_WEBHOOK_SECRET="change-this-webhook-secret"
EMAIL_WEBHOOK_SECRET="change-this-email-secret"
